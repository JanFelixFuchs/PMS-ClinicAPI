        </mxCell>
        <mxCell id="FAZBOnKlFszyejsRPEJr-10" value="&lt;b&gt;&lt;font style=&quot;&quot;&gt;Result&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;- deletable but not archivable&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;- not deleteable if:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- already deleted&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- patient is archived&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;&quot;&gt;- not changeable if:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- (no update method)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;table border=&quot;1&quot; style=&quot;border: 1px solid rgb(0, 0, 0); border-collapse: collapse;&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;&lt;font style=&quot;&quot;&gt;Property&lt;/font&gt;&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;&lt;font style=&quot;&quot;&gt;Constructor&lt;br&gt;initialization&lt;/font&gt;&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;&lt;font style=&quot;&quot;&gt;Restrictions&lt;/font&gt;&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Id&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;generated&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;ClinicId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Clinic&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not null&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Title&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not whitespace,&lt;br&gt;empty, or longer&lt;br&gt;max length&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;DateOfCreation&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not null,&amp;nbsp;&lt;br&gt;not in future&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Appendix&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not null, empty, &lt;br&gt;or above &lt;br&gt;maximum size&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;IsDeleted&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;no&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Remarks&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not whitespace,&lt;br&gt;empty, or longer&lt;br&gt;max length&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;PatientId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Patient&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;not null, deleted&lt;br&gt;or archived&lt;br&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;ClinicianId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Clinician&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;not null, deleted&lt;br&gt;or archived&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;DeviceId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Device&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;not null, deleted&lt;br&gt;or archived&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;&quot;&gt;- other methods:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Delete()&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- toString()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Equals()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- GetHashCode()&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="2900" y="2720" width="270" height="610" as="geometry" />
        </mxCell>
        <mxCell id="aWvuZXlEhvkCqQ6HBmH0-1" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Guidelines on modeling relationships in C# and .NET (EFCore):&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;- N:M relationship&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- both sides of the relationship receive a property of type ICollection&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- EFCore does not provide built-in tools for required N:M relationships (therefore validation needs to be done within the business logic)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the given properties can be used for navigation as well (assuming they are including during querying)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- although not required, it is recommended to have only one side managing the relationship&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- EFCore can be enabled to automatically create and manage N:M join-entity tables&lt;br&gt;&lt;/div&gt;&lt;div&gt;- 1:N relationship&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- one side of the relationship receives a property of type ICollection (this is the strong, non-managing side)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the other side of the relationship receives two properties (this is the weak, managing side):&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- one property is of the entity type (navigational property)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the second property is the id type (actual foreign key)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the strong, non-managing side of the relationship is always optional (therefore validation needs to be done within the business logic)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the weak, managing side of the relationship can be set to optional by making the properties nullable&lt;br&gt;&lt;/div&gt;&lt;div&gt;- 1:1 relationship&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- both sides of the relationship receive a property of the opposite type as navigation property&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- the weak, managing side of the relationship also receives an id type property (actual foreign key)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- by making the properties nullable each of the two sides of the relationship can be made optional&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- notice that just as any other information on database modeling, relationships should be configured within the database context class and its onModelCreation method&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Guideline on type declaration and property initialization:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;- reference types should be initialized otherwise their value is automatically null&lt;/div&gt;&lt;div&gt;- value types are typically not initialized&lt;/div&gt;&lt;div&gt;- in both cases the question mark operator can be used in oder to declare the property as nullable&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="2880" y="-800" width="910" height="360" as="geometry" />
        </mxCell>
        <mxCell id="aWvuZXlEhvkCqQ6HBmH0-2" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Legend:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- blue: non-managing (weak) side in relationships&lt;/span&gt;&lt;/div&gt;&lt;div&gt;- magenta: managing (strong) side in relationships&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="2880" y="-920" width="290" height="60" as="geometry" />
        </mxCell>
        <mxCell id="thTv4G8sO4jFJlJh_Fdq-27" value="Role" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;fillColor=#6a00ff;fontColor=#ffffff;strokeColor=#3700CC;" parent="1" vertex="1">
          <mxGeometry x="2480" y="2040" width="280" height="300" as="geometry" />
        </mxCell>
        <mxCell id="thTv4G8sO4jFJlJh_Fdq-28" value="Id: Guid" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontStyle=1" parent="thTv4G8sO4jFJlJh_Fdq-27" vertex="1">
