t;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;no&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;span&gt;not null, deleted&lt;/span&gt;&lt;br&gt;&lt;span&gt;or archived&lt;/span&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;ClinicianId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;no&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Clinician&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font&gt;no&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;span&gt;not null, deleted&lt;/span&gt;&lt;br&gt;&lt;span&gt;or archived&lt;/span&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;RoomId&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;indirect&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;-&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Room&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;span&gt;not null, deleted&lt;/span&gt;&lt;br&gt;&lt;span&gt;or archived&lt;/span&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;Devices&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;yes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;&quot;&gt;&lt;span&gt;not null, or&lt;/span&gt;&lt;br&gt;&lt;span&gt;containing deleted,&lt;/span&gt;&lt;br&gt;&lt;span&gt;archived or&lt;/span&gt;&lt;br&gt;&lt;span&gt;duplicates, or&lt;/span&gt;&lt;br&gt;&lt;span&gt;not operational&lt;/span&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;- other methods:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Start()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Complete()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- toString()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Equals()&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- GetHashCode()&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#000000;" parent="1" vertex="1">
